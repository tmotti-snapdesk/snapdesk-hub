# ========================================================================
# Snapdesk Hub — template de variables d'environnement
# Copier ce fichier en `.env.local` et remplir les valeurs.
# Ne jamais commiter `.env.local` (il est dans .gitignore).
# ========================================================================

# -------- Base de données Supabase --------
# Récupérer dans Supabase → Project → Connect → ORMs → Prisma
# DATABASE_URL = transaction pooler (port 6543) — utilisée par l'app Next.js
# DIRECT_URL   = direct/session (port 5432) — utilisée pour les migrations Prisma
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

# -------- NextAuth --------
# Générer un secret avec : openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
AUTH_SECRET=""

# -------- Resend (emails) --------
# Créer une clé sur https://resend.com → API Keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Snapdesk <onboarding@resend.dev>"

# -------- Google Gemini (LLM) --------
# Créer une clé sur https://aistudio.google.com
GOOGLE_GEMINI_API_KEY=""
# Optionnel — modèle utilisé pour reformuler les CR de visite.
# Défaut : gemini-2.5-flash-lite (gratuit dans le free tier actuel).
# Alternatives gratuites : gemini-2.0-flash-lite, gemini-1.5-flash, gemini-1.5-flash-8b
GEMINI_MODEL=""

# -------- Webhook Google Sheet -> Snapdesk --------
# Secret partagé entre le script Apps Script du Sheet et notre webhook.
# Générer avec : openssl rand -hex 32
SHEET_WEBHOOK_SECRET=""
